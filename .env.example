# ============================================================================
# Calling Agent — environment configuration
# Copy to .env for local dev:  cp .env.example .env
# On Railway, set these as service variables (railway variables --set ...).
# ============================================================================

# --- Server ---
# Railway injects PORT automatically; locally we default to 8080.
PORT=8080
# Public HTTPS base URL of this service (no trailing slash). Used to display the
# exact URLs you must paste into the VoiceLink panel.
APP_BASE_URL=https://call.radianmedia.org
LOG_LEVEL=info

# --- Dashboard auth (the dashboard + /api/* are public, so protect them) ---
# If left blank, a random password/secret is generated at boot and printed to
# the logs (fine for local dev; ALWAYS set explicitly in production).
DASHBOARD_PASSWORD=
SESSION_SECRET=

# --- Shared secrets VoiceLink uses to reach us (it can't send dashboard cookies) ---
# These become part of the WSS + webhook URLs you configure in the VoiceLink panel.
# If blank, generated at boot and printed to logs.
WSS_TOKEN=
WEBHOOK_TOKEN=

# --- Sarvam AI (the AI brain) — get your key at https://dashboard.sarvam.ai ---
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai
# Chat/LLM model. Candidates: sarvam-m, sarvam-30b, sarvam-105b.
# Run `npm run doctor` (or the Settings > Test Sarvam button) to see which responds.
SARVAM_CHAT_MODEL=sarvam-m
# Speech-to-text model (auto language detection is used by default).
SARVAM_STT_MODEL=saaras:v3
# Text-to-speech model + default voice. bulbul:v2 speakers: anushka, manisha,
# vidya, arya, abhilash, karun, hitesh. bulbul:v3 speakers: shubh, aditya, ...
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka

# Default language mode for new agents: "auto" (detect per-utterance) or a
# BCP-47 code like en-IN, hi-IN, ta-IN, etc.
DEFAULT_LANGUAGE=auto
# Language used for the opening greeting and when detection is uncertain.
TTS_FALLBACK_LANGUAGE=en-IN

# --- VoiceLink outbound "Add Lead / trigger call" API (behind their panel login) ---
# Fill these once you copy the values from the VoiceLink panel > API Documentation.
# Until then, inbound calls work but outbound triggering is disabled.
VOICELINK_LEAD_API_URL=
VOICELINK_LEAD_API_KEY=
# How the key is sent: bearer (Authorization: Bearer KEY) | header (custom header) | query (?<name>=KEY) | none
VOICELINK_LEAD_AUTH_STYLE=bearer
# For auth style "header" or "query": the parameter/header name that carries the key.
VOICELINK_LEAD_AUTH_NAME=Authorization
VOICELINK_LEAD_METHOD=POST
# Names of the fields in VoiceLink's request body/query for the destination number and the DID.
VOICELINK_LEAD_FIELD_PHONE=customer_number
VOICELINK_LEAD_FIELD_DID=did_number
# Optional: field name VoiceLink expects for extra custom params (JSON string). Leave blank if unused.
VOICELINK_LEAD_FIELD_PARAMS=custom_parameters
# Any additional static fields required by the Lead API, as a JSON object.
VOICELINK_LEAD_EXTRA_JSON={}

# --- Storage ---
# Where the JSON store lives. In production this is the mounted Railway volume.
DATA_DIR=./data

# --- Voice activity detection / turn-taking tunables ---
VAD_THRESHOLD=650
VAD_SILENCE_MS=700
VAD_MIN_SPEECH_MS=250
UTTERANCE_MAX_MS=15000
GREETING_ENABLED=true
